{
  "manifest_version": 3,
  "name": "Linguee \u2192 Anki",
  "version": "0.1.0",
  "description": "Extract German-English vocabulary from Linguee and add flashcards to Anki via AnkiConnect.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost/",
    "http://127.0.0.1/",
    "https://www.linguee.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linguee.com/*/search*",
        "https://www.linguee.com/*/translation*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Linguee \u2192 Anki"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "linguee-anki-bot@addons.mozilla.org",
      "strict_min_version": "151.0"
    }
  }
}
